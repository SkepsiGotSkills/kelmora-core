#!/usr/bin/env bash
# shellcheck shell=bash
# Kelmora Installer entry point. See README.md for supported platforms and scope.

set -Eeuo pipefail
IFS=$'\n\t'

readonly KELMORA_VERSION="28.0.0-alpha.1"
readonly KELMORA_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
readonly KELMORA_HOME="/usr/local/lib/kelmora"
readonly KELMORA_STATE_DIR="/var/lib/kelmora"
readonly KELMORA_CONFIG_DIR="/etc/kelmora"
readonly KELMORA_BIN_PATH="/usr/local/bin/kelmora"

# shellcheck source=lib/common.sh
source "${KELMORA_ROOT}/lib/common.sh"
# shellcheck source=lib/ui.sh
source "${KELMORA_ROOT}/lib/ui.sh"
# shellcheck source=lib/platform.sh
source "${KELMORA_ROOT}/lib/platform.sh"
# shellcheck source=lib/plan.sh
source "${KELMORA_ROOT}/lib/plan.sh"
# shellcheck source=lib/onboarding.sh
source "${KELMORA_ROOT}/lib/onboarding.sh"
# shellcheck source=lib/install.sh
source "${KELMORA_ROOT}/lib/install.sh"

usage() {
    cat <<EOF
Kelmora Installer ${KELMORA_VERSION}

Usage: sudo bash kelmora-installer [command] [options]

Commands:
  onboard       Start the guided installation experience (default)
  install       Install the selected/default Kelmora profile
  plan          Detect the VPS and print the default installation plan
  detect        Print local VPS compatibility information; makes no changes
  update        Upgrade APT packages and redeploy Kelmora-managed files
  uninstall     Remove Kelmora-managed files; APT packages are retained
  help          Show this help

Options:
  --dry-run       Build and review a plan but never change the VPS
  --yes           Accept confirmation prompts
  --profile NAME  Choose core, hosting, or developer (install only)
  --tune-network  Apply BBR only when platform detection verifies support
  --no-color      Disable terminal colour and animation
EOF
}

main() {

# If launched via curl | bash, reconnect stdin to the terminal.
if [[ ! -t 0 && -r /dev/tty ]]; then
    exec </dev/tty
fi

local command="onboard"
    if [[ ${1:-} == "--help" || ${1:-} == "-h" ]]; then
        usage
        return 0
    fi
    [[ $# -gt 0 && "${1}" != --* ]] && { command=$1; shift; }

    kelmora_parse_options "$@"
    ui_init
    platform_detect

    case "${command}" in
        onboard) kelmora_require_root; onboarding_run ;;
        install)
            kelmora_require_root
            platform_require_supported
            plan_build "${KELMORA_PROFILE}"
            install_apply_plan
            ;;
        plan)
            kelmora_require_root
            platform_require_supported
            plan_build "${KELMORA_PROFILE}"
            plan_render
            ;;
        detect) platform_render_report ;;
        update)
            kelmora_require_root
            platform_require_supported
            install_update
            ;;
        uninstall) kelmora_require_root; install_uninstall ;;
        help|-h|--help) usage ;;
        *) kelmora_die "Unknown command: ${command}. Run 'help' for usage." ;;
    esac
}

main "$@"
